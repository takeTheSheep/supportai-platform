generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPPORT_MANAGER
  SUPPORT_AGENT
}

enum ConversationStatus {
  RESOLVED
  UNRESOLVED
  ESCALATED
}

enum EscalationStatus {
  NEW_ESCALATION
  ASSIGNED
  WAITING_ON_CUSTOMER
  RESOLVED
}

enum FeedbackRating {
  HELPFUL
  NOT_HELPFUL
  NONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ArticleStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum Channel {
  WIDGET
  EMAIL
  WEB
}

enum Sender {
  USER
  ASSISTANT
  SYSTEM
}

enum NotificationType {
  ESCALATION
  DIGEST
  SECURITY
  SYSTEM
}

model Workspace {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  supportEmail      String
  defaultLanguage   String             @default("en")
  timezone          String             @default("UTC")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  memberships       Membership[]
  conversations     Conversation[]
  knowledgeCategories KnowledgeCategory[]
  knowledgeArticles KnowledgeArticle[]
  widgetConfig      WidgetConfig?
  assistantSettings AssistantSettings?
  notifications     Notification[]
  auditLogs         AuditLog[]
  promptPresets     PromptPreset[]
  tags              ConversationTag[]
  escalations       Escalation[]
  teamNotes         TeamNote[]
}

model User {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  memberships      Membership[]
  sessions         Session[]
  accounts         Account[]
  notes            TeamNote[]
  assignedConversations Conversation[] @relation("ConversationOwner")
  assignedEscalations   Escalation[]   @relation("EscalationAssignee")
  notifications    Notification[]
  auditLogs        AuditLog[]
  knowledgeArticles KnowledgeArticle[] @relation("ArticleOwner")
  assistantSettingUpdates AssistantSettings[] @relation("AssistantSettingsEditor")
  widgetConfigUpdates WidgetConfig[] @relation("WidgetConfigEditor")
}

model Membership {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
}

model Conversation {
  id               String              @id @default(cuid())
  workspaceId      String
  customerLabel    String
  topic            String
  status           ConversationStatus  @default(UNRESOLVED)
  channel          Channel             @default(WIDGET)
  source           String
  scenario         String
  confidence       Float               @default(0.75)
  flaggedForReview Boolean             @default(false)
  assignedOwnerId  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  resolvedAt       DateTime?

  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedOwner    User?               @relation("ConversationOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  messages         Message[]
  feedback         ConversationFeedback?
  escalation       Escalation?
  tags             ConversationTag[]
  notes            TeamNote[]

  @@index([workspaceId, status])
  @@index([workspaceId, updatedAt])
  @@index([assignedOwnerId])
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  sender           Sender
  text             String
  confidence       Float?
  suggestedPrompts Json?
  createdAt        DateTime     @default(now())

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ConversationFeedback {
  id             String         @id @default(cuid())
  conversationId String         @unique
  rating         FeedbackRating @default(NONE)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Escalation {
  id             String           @id @default(cuid())
  workspaceId    String
  conversationId String           @unique
  status         EscalationStatus @default(NEW_ESCALATION)
  priority       Priority         @default(MEDIUM)
  assignedAgentId String?
  reason         String
  dueAt          DateTime
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedAgent  User?            @relation("EscalationAssignee", fields: [assignedAgentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([assignedAgentId])
}

model KnowledgeCategory {
  id          String             @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  articles    KnowledgeArticle[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model KnowledgeArticle {
  id          String        @id @default(cuid())
  workspaceId String
  categoryId  String
  title       String
  summary     String
  content     String
  tags        Json
  status      ArticleStatus @default(DRAFT)
  sourceTag   String
  ownerId     String?
  usageCount  Int           @default(0)
  versionNote String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category    KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  owner       User?         @relation("ArticleOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([categoryId])
  @@index([usageCount])
}

model WidgetConfig {
  id                    String    @id @default(cuid())
  workspaceId           String    @unique
  primaryColor          String
  greetingMessage       String
  widgetTitle           String
  launcherPosition      String    @default("RIGHT")
  borderRadius          String    @default("ROUNDED")
  avatarStyle           String    @default("ORBIT")
  promptChips           Json
  businessHoursMessage  String
  showEscalation        Boolean   @default(true)
  updatedById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy             User?     @relation("WidgetConfigEditor", fields: [updatedById], references: [id], onDelete: SetNull)
}

model AssistantSettings {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  responseStyle       String    @default("BALANCED")
  tonePreset          String    @default("ENTERPRISE")
  escalationThreshold Int       @default(55)
  confidenceThreshold Int       @default(62)
  restrictedTopics    Json
  fallbackMessage     String
  updatedById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy           User?     @relation("AssistantSettingsEditor", fields: [updatedById], references: [id], onDelete: SetNull)
}

model TeamNote {
  id             String       @id @default(cuid())
  workspaceId    String
  conversationId String
  authorId       String
  content        String
  createdAt      DateTime     @default(now())

  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId])
}

model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  type        NotificationType
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, readAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String?
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([targetType, targetId])
}

model PromptPreset {
  id          String   @id @default(cuid())
  workspaceId String
  scenario    String
  name        String
  prompt      String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, scenario])
}

model ConversationTag {
  id             String       @id @default(cuid())
  workspaceId    String
  conversationId String
  label          String
  createdAt      DateTime     @default(now())

  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, label])
  @@index([workspaceId, label])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
